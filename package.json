{
  "name": "nuru",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Nuru — a daily glyph-deduction puzzle. Light the grid to reveal a hidden glyph; always solvable, never a guess.",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "nuru": "cli/index.ts"
  },
  "scripts": {
    "nuru": "tsx cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.web.json",
    "dev": "vite",
    "build:web": "vite build",
    "deploy": "vite build && touch dist/.nojekyll && npx --yes gh-pages@6 -d dist --dotfiles",
    "batch": "tsx cli/index.ts batch --n 1000 --ladder"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.23.1",
    "typescript": "^5.6.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
